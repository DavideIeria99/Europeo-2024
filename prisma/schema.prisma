generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["multiSchema"]
}

datasource db {
    provider = "mysql"
    url      = env("MYSQL_URL") // uses connection pooling
}

model Nation {
    id    Int     @id @default(autoincrement())
    name  String  @unique
    image String
    Point Groups?

    @@map("nation") // Mapping the table name explicitly for MySQL
}

model Groups {
    id         Int    @id @default(autoincrement())
    nationName String @unique
    Nation     Nation @relation(fields: [nationName], references: [name])
    Groups     String
    pts        Int    @default(0)
    PG         Int    @default(0)
    victory    Int    @default(0)
    tie        Int    @default(0)
    loser      Int    @default(0)
    GS         Int    @default(0)
    GC         Int    @default(0)
    DR         Int    @default(0)

    @@map("groups") // Mapping the table name explicitly for MySQL
}

model DirectState {
    id        Int     @id @default(autoincrement())
    nation    String  @unique
    OneEight  Boolean @default(false)
    OneFour   Boolean @default(false)
    SemiFinal Boolean @default(false)
    Final     Boolean @default(false)
    Winner    Boolean @default(false)

    @@map("direct_state") // Mapping the table name explicitly for MySQL
}
